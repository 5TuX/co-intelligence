{% extends "base.html.j2" %}

{% block title %}{{ ctx.user_name or "Job Search" }} Dashboard – {{ ctx.date }}{% endblock %}

{% block body %}
<h1>{{ ctx.user_name or "Job Search" }} Dashboard</h1>
<p class="date-updated">Last updated {{ ctx.date }}</p>

<nav class="tabs">
  <button class="tab active" data-target="tab-offers">Offers ({{ ctx.offers | length }})</button>
  {% if summary %}<button class="tab" data-target="tab-summary">Run Summary</button>{% endif %}
  {% if schedule %}<button class="tab" data-target="tab-learning">Learning Path</button>{% endif %}
</nav>

{# ── Offers tab ── #}
<section id="tab-offers" class="tab-panel active">
<h2>All Offers</h2>
<table>
<tr><th class="sortable">#</th><th class="sortable">Role</th><th class="sortable">Company</th><th class="sortable">Location</th><th class="sortable">Domain</th><th class="sortable">Level / Salary</th><th class="sortable">Mission</th><th class="sortable">Tools</th><th class="sortable">Match</th></tr>
{% for o in ctx.offers %}
<tr>
  <td>{{ loop.index }}</td>
  <td><a href="{{ o.url }}" target="_blank">{{ o.role }}</a>{% if o.deadline %} <span class="deadline-badge" data-deadline="{{ o.deadline }}">{{ o.deadline }}</span>{% endif %}</td>
  <td>{{ o.company }}</td>
  <td>{{ o.location }}</td>
  <td>{{ o.domain }}</td>
  <td>{% if o.level and o.salary %}{{ o.level }} · {{ o.salary }}{% elif o.level %}{{ o.level }}{% elif o.salary %}{{ o.salary }}{% endif %}</td>
  <td>{{ o.mission }}</td>
  <td>{{ o.tools }}</td>
  <td><span class="match-score">{{ o.match }}</span></td>
</tr>
{% endfor %}
</table>

{% if ctx.people %}
<h2>People to Follow / Contact</h2>
<table>
<tr><th>Person</th><th>Affiliation</th><th>Domain</th><th>How to reach</th></tr>
{% for p in ctx.people %}
<tr>
  <td>{{ p.name }}</td>
  <td>{{ p.affiliation }}</td>
  <td>{{ p.domain }}</td>
  <td>{{ p.reach }}</td>
</tr>
{% endfor %}
</table>
{% endif %}

{% if ctx.freelance %}
<h2>Freelance / Project-based Platforms</h2>
<table>
<tr><th>Platform</th><th>Search terms</th></tr>
{% for f in ctx.freelance %}
<tr>
  <td><a href="{{ f.url }}" target="_blank">{{ f.name }}</a></td>
  <td>{{ f.search_terms }}</td>
</tr>
{% endfor %}
</table>
{% endif %}
</section>

{# ── Summary tab ── #}
{% if summary %}
<section id="tab-summary" class="tab-panel">
<h2>Run Summary</h2>

{% if summary.tips %}
<div class="tips">
<h3>Tips & Recommendations</h3>
<ul>
{% for tip in summary.tips %}
  <li>{{ tip }}</li>
{% endfor %}
</ul>
</div>
{% endif %}

{% if summary.admin_notes %}
<div class="admin-notes">
<h3>Admin Notes</h3>
<ul>
{% for note in summary.admin_notes %}
  <li>{{ note }}</li>
{% endfor %}
</ul>
</div>
{% endif %}
</section>
{% endif %}

{# ── Learning Path tab ── #}
{% if schedule %}
<section id="tab-learning" class="tab-panel">
<h2>Learning Path</h2>
<p class="section-note">Skills to develop — pick what fits your energy and schedule. Sorted by priority.</p>

{% if schedule.method %}
<div class="tips">
<h3>Session Structure</h3>
<p><strong>{{ schedule.method.daily_pattern }}</strong></p>
<ul>
{% for p in schedule.method.principles %}
  <li>{{ p }}</li>
{% endfor %}
</ul>
</div>
{% endif %}

<table>
<tr><th class="sortable">Priority</th><th class="sortable">Skill</th><th>Difficulty</th><th>Why</th></tr>
{% for item in schedule.schedule %}
<tr>
  <td><span class="match-score">{{ item.priority }}</span></td>
  <td>{{ item.skill }}</td>
  <td>{{ item.difficulty }}</td>
  <td>{{ item.why }}</td>
</tr>
{% endfor %}
</table>

{% for item in schedule.schedule %}
<h3>{{ item.skill }}</h3>
{% if item.topics %}
<p><strong>Topics:</strong> {{ item.topics | join(", ") }}</p>
{% endif %}
{% if item.resources %}
<ul>
{% for r in item.resources %}
  <li>{{ r.label }}{% if r.url %} — <a href="{{ r.url }}" target="_blank">{{ r.url }}</a>{% endif %}</li>
{% endfor %}
</ul>
{% endif %}
{% endfor %}
</section>
{% endif %}
{% endblock %}
