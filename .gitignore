# User private data (career files, CVs, preferences, job offers)
**/users/*/
!**/users/_example/

# Python
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/

# uv
uv.lock

# Generated HTML (rebuilt from data)
*.html
!**/templates/*.html.j2

# Data files with personal info
*.json
!**/data/*.json

# OS
.DS_Store
Thumbs.db

# Editor
*.swp
*.swo
*~

# Secrets
.env
*.key
credentials.*
